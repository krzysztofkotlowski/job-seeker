{
  "realm": "jobseeker",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "jobseeker-frontend",
      "name": "Job Seeker Frontend",
      "description": "Job Seeker Tracker SPA",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false
    }
  ]
}
