# Job Seeker Tracker — Production environment
# Copy to project root as .env on the server before first deployment:
#   cp deploy/env.example.prod .env
# Then edit and set a strong POSTGRES_PASSWORD for production.

# Database (set a strong password in production)
POSTGRES_PASSWORD=jobseeker

# AI / LLM
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=all-minilm
EMBED_DIMS=384
LLM_MAX_OUTPUT_TOKENS=400
RAG_ENABLED=true

# thin-llama source checkout for deployment (pin to a tag or commit)
THIN_LLAMA_GIT_URL=https://github.com/krzysztofkotlowski/thin-llama.git
THIN_LLAMA_GIT_REF=b6235a57899ec466e892b9361babf72aaecfcea1

# Auth (optional; set KEYCLOAK_ENABLED=true to enable)
KEYCLOAK_ENABLED=false
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# CORS: comma-separated origins or * for same-origin (frontend proxies API)
CORS_ORIGINS=*
